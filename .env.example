# --- LLM provider ---------------------------------------------------------
# One of: openai | anthropic | openai-compatible. Leave blank to disable LLM
# tools cleanly (understand_code / summarize_code return LlmNotConfigured).
LLM_PROVIDER=
LLM_API_KEY=
# Required when LLM_PROVIDER=openai-compatible. Optional override otherwise.
LLM_BASE_URL=
# Optional. Falls back to a provider-appropriate default if unset.
LLM_DEFAULT_MODEL=

# --- Browser ---------------------------------------------------------------
# Camoufox binary. macOS default: /Applications/Camoufox.app/Contents/MacOS/camoufox
# Override here when installed elsewhere, or pass --camoufox-path.
CAMOUFOX_PATH=
# geckodriver binary. Default: /usr/local/bin/geckodriver
# Apple Silicon brew installs to /opt/homebrew/bin/geckodriver — set it here.
GECKODRIVER_PATH=
